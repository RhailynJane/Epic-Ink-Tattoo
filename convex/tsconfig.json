{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2021", "dom"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "paths": {}
  },
  "include": ["./**/*.ts", "./**/*.tsx", "../node_modules/.generated/convex/**/*.d.ts"],
  "exclude": ["../node_modules"]
}
